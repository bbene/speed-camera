# PostgreSQL Database Configuration
# Used by Docker Compose and the speed-camera application

# Database connection URL
DATABASE_URL=postgresql://speed_camera:speed_camera_password@postgres:5432/speed_camera

# Database credentials (used by Docker Compose)
POSTGRES_USER=speed_camera
POSTGRES_PASSWORD=speed_camera_password
POSTGRES_DB=speed_camera

# Flask web interface
FLASK_PORT=5000
FLASK_DEBUG=0
